#!/bin/bash
set -e

# builder.py will dynamically replace {pkg_name} with the actual package name
PACKAGE_NAME="{pkg_name}"
DEPS_DIR="/opt/airgap/${PACKAGE_NAME}/deps"
PAYLOAD_DIR="/opt/airgap/${PACKAGE_NAME}/payload"
LOG_FILE="/var/log/airgap_${PACKAGE_NAME}_install.log"
DAEMON_SCRIPT="/tmp/airgap_daemon_${PACKAGE_NAME}.sh"

echo "======================================================"
echo " Staging Post-Installation Dependency Setup (ARM64)"
echo "======================================================"

# __PAYLOAD_INSTALL_SNIPPET__

# __KERNEL_MODULE_SNIPPET__

# __VERIFY_SNIPPET__

# Check if the nested dependencies directory exists and contains .deb files
if [ -d "$DEPS_DIR" ] && ls "$DEPS_DIR"/*.deb 1> /dev/null 2>&1; then
    echo "[*] Found offline .deb files to install."
    echo "[*] Spawning detached daemon to bypass dpkg frontend lock..."
    echo "[*] Installation logs will be routed to: $LOG_FILE"
    
    # Capture the Process ID (PID) of the currently running dpkg lock-holder
    DPKG_PID=$PPID

    # Generate the detached background daemon script
    cat << EOF > "$DAEMON_SCRIPT"
#!/bin/bash
echo "\$(date): Waiting for primary dpkg process (PID: $DPKG_PID) to release locks..." > "$LOG_FILE"

# Loop continuously while the parent dpkg process is still active
while kill -0 $DPKG_PID 2>/dev/null; do
    sleep 1
done

# Execute a brief safety delay to ensure the OS has fully flushed the lock files
sleep 2

echo "\$(date): Locks released. Installing bundled ARM64 dependencies..." >> "$LOG_FILE"

# Execute the nested installation
dpkg -i "$DEPS_DIR"/*.deb >> "$LOG_FILE" 2>&1

echo "\$(date): Refreshing shared library cache via ldconfig..." >> "$LOG_FILE"
ldconfig >> "$LOG_FILE" 2>&1

echo "\$(date): Nested dependency installation finalized successfully." >> "$LOG_FILE"

# Delete the temporary daemon script to leave no trace
rm -f "$DAEMON_SCRIPT"
EOF

    # Grant execution permissions to the generated daemon
    chmod 755 "$DAEMON_SCRIPT"
    
    # Execute the daemon in the background, fully detached from standard inputs/outputs
    nohup "$DAEMON_SCRIPT" </dev/null >/dev/null 2>&1 &
    
    echo "[*] Daemon spawned successfully. Dependencies will finish installing momentarily."

else
    echo "[*] No nested system dependencies found. Skipping offline configuration."
fi

echo "======================================================"
echo "[SUCCESS] Installation finalized!"
echo "======================================================"
exit 0